{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@domain": ["../domain/src/index.ts"],
      "@application": ["../application/src/index.ts"],
      "@infrastructure": ["../infrastructure/src/index.ts"]
    }
  },
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"],
  "include": ["src"],
  "references": [
    { "path": "../domain" },
    { "path": "../application" },
    { "path": "../infrastructure" }
  ]
}
